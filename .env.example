# OpenRouter (free tier) — get key at https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_key_here

# Best free models on OpenRouter (pick one, set below)
# meta-llama/llama-3.1-8b-instruct:free
# mistralai/mistral-7b-instruct:free
# google/gemma-2-9b-it:free
ORCHESTRATOR_MODEL=meta-llama/llama-3.1-8b-instruct:free

# App settings
APP_ENV=development
LOG_LEVEL=INFO

# Redis (optional for now — we use in-memory fallback)
REDIS_URL=redis://localhost:6379
USE_REDIS=false
